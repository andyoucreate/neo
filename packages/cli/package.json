{
  "name": "@neotx/cli",
  "version": "0.1.0-alpha.2",
  "description": "CLI for the Neo orchestration framework",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andyoucreate/neo.git",
    "directory": "packages/cli"
  },
  "bin": {
