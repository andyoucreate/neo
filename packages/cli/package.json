{
  "name": "@neotx/cli",
  "version": "0.1.0-alpha.26",
  "description": "CLI for the Neo orchestration framework",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andyoucreate/neo.git",
    "directory": "packages/cli"
  },
  "bin": {
    "neo": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-agents",
    "claude",
    "cli",
    "orchestration",
    "autonomous-agents",
    "developer-tools"
  ],
  "engines": {
    "node": ">=22"
  },
  "man": [
    "../../man/man1/neo.1",
    "../../man/man1/neo-agents.1",
    "../../man/man1/neo-cost.1",
    "../../man/man1/neo-doctor.1",
    "../../man/man1/neo-init.1",
    "../../man/man1/neo-log.1",
    "../../man/man1/neo-logs.1",
    "../../man/man1/neo-mcp.1",
    "../../man/man1/neo-memory.1",
    "../../man/man1/neo-repos.1",
    "../../man/man1/neo-run.1",
    "../../man/man1/neo-runs.1",
    "../../man/man1/neo-supervise.1",
    "../../man/man1/neo-version.1"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run",
    "install-man": "mkdir -p /usr/local/share/man/man1 && cp ../../man/man1/*.1 /usr/local/share/man/man1/ && mandb 2>/dev/null || true"
  },
  "dependencies": {
    "@neotx/agents": "workspace:*",
    "@neotx/core": "workspace:*",
    "citty": "^0.2.1",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.5.1"
  }
}
