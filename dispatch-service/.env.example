# Voltaire Dispatch Service — Environment Configuration
# Copy to .env and fill in values

# ─── Server ──────────────────────────────────────────────────
DISPATCH_PORT=3001
DISPATCH_HOST=127.0.0.1

# ─── Authentication ──────────────────────────────────────────
# Bearer token for /dispatch/* endpoints (leave empty to disable auth)
DISPATCH_AUTH_TOKEN=

# ─── Claude Code Authentication ────────────────────────────────
# The Agent SDK uses Claude Code CLI credentials (~/.claude/.credentials).
# Run `claude login` as the voltaire user — no ANTHROPIC_API_KEY needed here.

# ─── Callback (OpenClaw) ─────────────────────────────────────
# URL to notify OpenClaw on pipeline completion and service events
# Default: http://127.0.0.1:18789/hooks/dispatch-result
CALLBACK_URL=
# Bearer token for OpenClaw hooks endpoint (must match OpenClaw hooks.token)
OPENCLAW_HOOKS_TOKEN_DISPATCH=

# ─── Claude Code ────────────────────────────────────────────
# Path to the Claude Code CLI binary (npm install -g @anthropic-ai/claude-code)
CLAUDE_CODE_PATH=/usr/local/bin/claude

# ─── Paths ───────────────────────────────────────────────────
COST_JOURNAL_DIR=/opt/voltaire/costs
AUDIT_LOG_PATH=/opt/voltaire/logs/audit.log
EVENT_JOURNAL_PATH=/opt/voltaire/events/journal.jsonl

# ─── Git Worktrees ───────────────────────────────────────────
WORKTREE_BASE=/tmp/voltaire-worktrees
