# Voltaire Dispatch Service — Environment Configuration
# Copy to .env and fill in values

# ─── Server ──────────────────────────────────────────────────
DISPATCH_PORT=3001
DISPATCH_HOST=127.0.0.1

# ─── Authentication ──────────────────────────────────────────
# Bearer token for /dispatch/* endpoints (leave empty to disable auth)
DISPATCH_AUTH_TOKEN=

# ─── Anthropic API ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Slack Notifications ─────────────────────────────────────
# Incoming webhook URL for pipeline status notifications
SLACK_WEBHOOK_URL=

# ─── Paths ───────────────────────────────────────────────────
COST_JOURNAL_DIR=/opt/voltaire/costs
AUDIT_LOG_PATH=/opt/voltaire/logs/audit.log
EVENT_JOURNAL_PATH=/opt/voltaire/events/journal.jsonl

# ─── Git Worktrees ───────────────────────────────────────────
WORKTREE_BASE=/tmp/voltaire-worktrees
