# =============================================================================
# Voltaire Network — Environment Variables
# =============================================================================
# Copy this file to /opt/voltaire/.env and fill in the values.
# Permissions: root:voltaire 640 (set by bootstrap.sh)

# --- Anthropic API (OpenClaw only — see .env.openclaw) ---
# ANTHROPIC_API_KEY is NOT set here. It lives in /opt/voltaire/.env.openclaw
# so the dispatch service can use Claude Code CLI credentials instead.

# --- OpenClaw Webhook Tokens (one per source for isolation) ---
OPENCLAW_HOOKS_TOKEN_NOTION=whsec_...
OPENCLAW_HOOKS_TOKEN_GITHUB=whsec_...
OPENCLAW_HOOKS_TOKEN_SLACK=whsec_...

# --- Notion Integration ---
NOTION_API_TOKEN=ntn_...

# --- GitHub Bot Account ---
GITHUB_TOKEN=ghp_...

# --- Slack Integration ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# --- Server Configuration ---
VOLTAIRE_DOMAIN=voltaire.yourdomain.com
VOLTAIRE_EMAIL=admin@yourdomain.com

# --- Alert Configuration ---
ALERT_EMAIL=karl@example.com
